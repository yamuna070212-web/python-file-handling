file = open("sample.txt", "r")

text = file.read().lower()

vowels = 0
consonants = 0

for ch in text:

    if ch.isalpha():

        if ch in "aeiou":
            vowels += 1
else:
            consonants += 1

print("Vowels =", vowels)
print("Consonants =", consonants)

file.close()
Output
Vowels = 22
Consonants = 35
