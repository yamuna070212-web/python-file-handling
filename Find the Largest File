import os

largest = ""
max_size = 0

for file in os.listdir("."):

    if os.path.isfile(file):

        size = os.path.getsize(file)

        if size > max_size:
            max_size = size
            largest = file

print("Largest File =", largest)
print("Size =", max_size, "bytes")
